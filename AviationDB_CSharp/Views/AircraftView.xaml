<Window x:Class="AviationDB_CSharp.Views.AircraftView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AviationDB_CSharp.Views"
        mc:Ignorable="d"
        Title="AircraftView" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <Button Content="Загрузить" Command="{Binding LoadAircraftsCommand}" Margin="0,0,10,0"/>
            <Button Content="Добавить" Command="{Binding AddAircraftCommand}" Margin="0,0,10,0"/>
            <Button Content="Сохранить" Command="{Binding SaveAircraftCommand}" Margin="0,0,10,0"/>
            <Button Content="Удалить" Command="{Binding DeleteAircraftCommand}"/>
        </StackPanel>

        <!-- Список самолетов -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding Aircrafts}" 
                  SelectedItem="{Binding SelectedAircraft}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код" Binding="{Binding AircraftCode}" Width="80"/>
                <DataGridTextColumn Header="Модель" Binding="{Binding Model}" Width="200"/>
                <DataGridTextColumn Header="Дальность (км)" Binding="{Binding Range}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Форма редактирования -->
        <GroupBox Grid.Row="2" Header="Редактирование" Margin="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Код самолета:" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditingAircraft.AircraftCode, UpdateSourceTrigger=PropertyChanged}" 
                         MaxLength="3" Margin="5"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Дальность:" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding EditingAircraft.Range, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Модель:" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" 
                         Text="{Binding EditingAircraft.Model, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="5"/>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
