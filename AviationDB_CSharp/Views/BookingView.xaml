<Window x:Class="AviationDB_CSharp.Views.BookingView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AviationDB_CSharp.Views"
        mc:Ignorable="d"
        Title="BookingView" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <Button Content="Загрузить" Command="{Binding LoadBookingsCommand}" Margin="0,0,10,0"/>
            <Button Content="Добавить" Command="{Binding AddBookingCommand}" Margin="0,0,10,0"/>
            <Button Content="Сохранить" Command="{Binding SaveBookingCommand}" Margin="0,0,10,0"/>
            <Button Content="Удалить" Command="{Binding DeleteBookingCommand}"/>
        </StackPanel>

        <!-- Список бронирований -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding Bookings}" 
                  SelectedItem="{Binding SelectedBooking}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер" Binding="{Binding BookRef}" Width="80"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding BookDate, StringFormat=dd.MM.yyyy HH:mm}" Width="120"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat=C2}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Форма редактирования -->
        <GroupBox Grid.Row="2" Header="Редактирование" Margin="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер брони:" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditingBooking.BookRef, UpdateSourceTrigger=PropertyChanged}" 
                         MaxLength="6" Margin="5"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Дата:" Margin="5" VerticalAlignment="Center"/>
                <DatePicker Grid.Row="0" Grid.Column="3" 
                           SelectedDate="{Binding EditingBooking.BookDate}"
                           Margin="5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Сумма:" Margin="5" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditingBooking.TotalAmount, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="5"/>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
